# Copy this file to .env.local and fill in your real values.
# .env.local is listed in .gitignore and must NEVER be committed to GitHub.
# In Azure App Service, set these same keys as Application Settings.

AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o

COSMOS_ENDPOINT=https://YOUR-ACCOUNT.documents.azure.com:443/
COSMOS_KEY=your-cosmos-readwrite-key-here
COSMOS_DATABASE=aide-db
COSMOS_CONTAINER=imv-reports
